{
  "expo": {
    "name": "TREND Coffee",
    "slug": "order-mobile-app",
    "version": "2.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/trend/logo-icon-padded.png",
    "scheme": "trend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cho phép ứng dụng sử dụng camera để chụp ảnh đại diện.",
        "NSPhotoLibraryUsageDescription": "Cho phép ứng dụng truy cập thư viện ảnh để chọn ảnh đại diện.",
        "NSPhotoLibraryAddUsageDescription": "Cho phép ứng dụng lưu ảnh hoá đơn và mã QR thanh toán vào thư viện ảnh.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.trendcoffee.order"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/trend/logo-icon-padded.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "versionCode": 40,
      "package": "com.trendcoffee.order"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/trend/logo-icon-padded.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Cho phép ứng dụng truy cập thư viện ảnh để chọn ảnh đại diện.",
          "savePhotosPermission": "Cho phép ứng dụng lưu ảnh hoá đơn và mã QR thanh toán vào thư viện ảnh.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": []
        }
      ],
      "expo-build-properties",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/trend/logo-icon-padded.png",
          "color": "#F7A737",
          "sounds": ["./assets/sound/notification.mp3"],
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/remove-permissions"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "jsEngine": "hermes",
    "extra": {
      "router": {}
    }
  }
}
